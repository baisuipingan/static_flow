# Copy this file to .local/llm-access-cloud-release.env and fill in local values.
# The .local directory is ignored by git.

# Keep Cargo build artifacts outside the repository checkout.
CARGO_TARGET_DIR=/path/to/large-disk/cargo-target/static_flow

# SSH target. Either set GCP_DEST directly, or set GCP_USER + GCP_HOST.
GCP_USER=your-ssh-user
GCP_HOST=your-gcp-host-or-ip
# GCP_DEST=your-ssh-user@your-gcp-host-or-ip

# SSH private key used by ssh/scp.
GCP_SSH_KEY=~/.ssh/your-gcp-key

# Directory on the remote host that receives staged release files.
REMOTE_RELEASE_DIR=/home/your-ssh-user/llm-access-release

# Remote service and install paths used by the activation script.
LLM_ACCESS_SERVICE=llm-access.service
LLM_ACCESS_USAGE_WORKER_SERVICE=llm-access-usage-worker.service
LLM_ACCESS_INSTALL_PATH=/usr/local/bin/llm-access
LLM_ACCESS_USAGE_WORKER_INSTALL_PATH=/usr/local/bin/llm-access-usage-worker
LLM_ACCESS_HEALTH_URL=http://127.0.0.1:19080/healthz
LLM_ACCESS_USAGE_WORKER_HEALTH_URL=http://127.0.0.1:19081/admin/llm-access/usage-worker/status

# llm-access service split. Keep API provider traffic on 19080 and DuckDB usage
# query/ingestion on the worker port.
LLM_ACCESS_USAGE_QUERY_BIND_ADDR=127.0.0.1:19081
LLM_ACCESS_USAGE_QUERY_BASE_URL=http://127.0.0.1:19081
# Local ignored source file for the live Neon control connection string.
# This file should define LLM_ACCESS_CONTROL_DATABASE_URL=postgresql://...
LLM_ACCESS_LOCAL_NEON_ENV_FILE=.local/llm-access-neon.env
# Shared Neon control config on the mounted control state. This file should
# define LLM_ACCESS_CONTROL_DATABASE_URL=postgresql://...
LLM_ACCESS_CONTROL_DATABASE_URL_FILE=/mnt/llm-access/config/neon.env
# Worker-local paths and the dedicated usage JuiceFS mount are now defined in
# the worker systemd unit template, not in this shared env file.

# Non-secret placeholders used by docs/runbooks. Fill real values only in the
# ignored .local copy.
PUBLIC_ORIGIN=https://your-public-domain.example
PB_MAPPER_RELAY_ADDR=your-relay-host:your-relay-port
PB_MAPPER_LOCAL_RELAY_ADDR=127.0.0.1:your-relay-port
PB_MAPPER_RELAY_PORT=your-relay-port
VALKEY_SSH_TARGET=your-valkey-user@your-valkey-host
JUICEFS_PRIVATE_ENV=.local/common/juicefs/llm-access.env

# Local build knobs.
BUILD_JOBS=4
ALLOW_DIRTY=0
