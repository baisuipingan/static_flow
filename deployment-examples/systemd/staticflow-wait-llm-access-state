#!/usr/bin/env bash
set -euo pipefail

mode="${1:-state}"
timeout="${LLM_ACCESS_READY_TIMEOUT_SECONDS:-120}"
mount_point="${LLM_ACCESS_STATE_ROOT:-${JUICEFS_MOUNT_POINT:-/mnt/llm-access}}"
sqlite_path="${LLM_ACCESS_SQLITE_CONTROL:-${mount_point}/control/llm-access.sqlite3}"
control_database_url="${LLM_ACCESS_CONTROL_DATABASE_URL:-}"
duckdb_path="${LLM_ACCESS_DUCKDB:-${mount_point}/analytics/usage.duckdb}"
duckdb_active_dir="${LLM_ACCESS_DUCKDB_ACTIVE_DIR:-}"
support_config="${LLM_ACCESS_SUPPORT_CONFIG:-${mount_point}/support/llm_access_support/config.json}"

if [[ "$mode" == "--mount-only" ]]; then
  mode="mount-only"
fi

for ((second = 0; second < timeout; second++)); do
  if mountpoint -q "$mount_point"; then
    if [[ "$mode" == "mount-only" ]]; then
      exit 0
    fi
    control_ready=0
    if [[ -n "$control_database_url" || -s "$sqlite_path" ]]; then
      control_ready=1
    fi
    duckdb_ready=0
    if [[ -n "$duckdb_active_dir" ]]; then
      duckdb_ready=1
    elif [[ -s "$duckdb_path" ]]; then
      duckdb_ready=1
    fi
    if [[ "$mode" == "api" && "$control_ready" == "1" && -s "$support_config" ]]; then
      exit 0
    fi
    if [[ "$mode" == "analytics" && "$control_ready" == "1" && "$duckdb_ready" == "1" ]]; then
      exit 0
    fi
    if [[ "$mode" == "state" && "$control_ready" == "1" && "$duckdb_ready" == "1" && -s "$support_config" ]]; then
      exit 0
    fi
  fi
  sleep 1
done

echo "llm-access state is not ready after ${timeout}s" >&2
echo "mount_point=${mount_point}" >&2
echo "sqlite_path=${sqlite_path}" >&2
echo "control_database_url=${control_database_url:+set}" >&2
echo "duckdb_path=${duckdb_path}" >&2
echo "duckdb_active_dir=${duckdb_active_dir}" >&2
echo "support_config=${support_config}" >&2
echo "mode=${mode}" >&2
findmnt -T "$mount_point" >&2 || true
exit 1
